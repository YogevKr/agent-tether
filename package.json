{
  "name": "agent-tether",
  "description": "Bind local coding-agent CLI sessions to Telegram topics and continue them across devices.",
  "version": "0.1.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YogevKr/agent-tether.git"
  },
  "homepage": "https://github.com/YogevKr/agent-tether#readme",
  "bugs": {
    "url": "https://github.com/YogevKr/agent-tether/issues"
  },
  "type": "module",
  "keywords": [
    "codex",
    "claude-code",
    "telegram",
    "agent",
    "cli",
    "hooks"
  ],
  "scripts": {
    "bot": "node src/relay.js",
    "worker": "node src/worker.js",
    "start-session": "node src/start-session.js",
    "discover-telegram": "node src/discover-telegram.js",
    "configure-telegram-bot": "node src/configure-telegram-bot.js",
    "install-global-hooks": "node src/install-global-hooks.js",
    "install-launch-agent": "node src/install-launch-agent.js",
    "uninstall-launch-agent": "node src/uninstall-launch-agent.js",
    "cleanup-stale": "node src/cleanup-stale.js",
    "smoke": "node src/smoke.js",
    "test": "node --test",
    "check": "node --check src/*.js test/*.js"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
