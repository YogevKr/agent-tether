TELEGRAM_BOT_TOKEN=
AUTHORIZED_TELEGRAM_USER_IDS=
TELEGRAM_FORUM_CHAT_ID=
CODEX_DEFAULT_CWD=
AGENT_PROVIDER=codex
RELAY_START_ROOTS=~/repos,~/projects
RELAY_HOST_ID=
RELAY_HUB_URL=
RELAY_HUB_TOKEN=
RELAY_HUB_BIND_HOST=127.0.0.1
RELAY_HUB_PORT=8787
RELAY_WORKER_CONCURRENCY=4
CODEX_BIN=codex
CODEX_DEFAULT_ARGS=--yolo
CODEX_MODEL=
CODEX_APPROVAL_POLICY=never
CODEX_SANDBOX_MODE=workspace-write
CODEX_SKIP_GIT_REPO_CHECK=true
CLAUDE_BIN=claude
CLAUDE_DEFAULT_ARGS=--dangerously-skip-permissions
CLAUDE_MODEL=
CLAUDE_PERMISSION_MODE=
WHISPER_BIN=whisper
# Optional. Default: OS app-data dir. Legacy ./data/state.json is still read on upgrade.
# In stateless deploys, point this at a mounted persistent path.
# If RELAY_HOST_ID is unset, agent-tether persists a generated host id next to STATE_FILE.
STATE_FILE=
POLL_TIMEOUT_SECONDS=30
TELEGRAM_API_BASE_URL=https://api.telegram.org
RELAY_AUTO_ARCHIVE_AFTER_DAYS=14
RELAY_AUTO_PRUNE_AFTER_DAYS=60
